  {
   "cell_type": "markdown",
   "metadata": {
    "id": "setup_intro"
   },
   "source": [
    "# 05 — Evaluation\n",
    "\n",
    "Evaluate trained model on validation data.\n",
    "Loads from **Google Drive**.\n",
    "\n",
    "> Runs on **Google Colab** (free T4 tier)."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "setup_install"
   },
   "source": [
    "## 1. Install dependencies"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "install_deps"
   },
   "outputs": [],
   "source": [
    "!pip install -q torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu118"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "setup_mount"
   },
   "source": [
    "## 2. Mount Google Drive (MANDATORY)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
    "metadata": {
     "id": "mount_drive"
    },
    "outputs": [],
    "source": [
     "from google.colab import drive\n",
     "drive.mount('/content/drive')"
    ]
   },
   "cell_type": "markdown",
   "metadata": {
    "id": "imports"
   },
   "source": [
    "## 3. Imports & Config"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "imports_cell"
   },
   "outputs": [],
   "source": [
    "import os, json, torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "from torch.utils.data import Dataset\n",
    "from tqdm.auto import tqdm\n",
    "import numpy as np\n",
    "\n",
    "DRIVE_BASE = \"/content/drive/MyDrive/ANTHOR\"\n",
    "print(f\"PyTorch: {torch.__version__}, CUDA: {torch.cuda.is_available()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "config"
   },
   "source": [
    "## 4. Configuration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "config_cell"
   },
   "outputs": [],
   "source": [
    "CONFIG = {\n",
    "    \"vocab_size\": 16384,\n",
    "    \"n_layers\": 12,\n",
    "    \"n_heads\": 12,\n",
    "    \"n_kv_heads\": 4,\n",
    "    \"d_model\": 768,\n",
    "    \"d_ff\": 2048,\n",
    "    \"max_seq_len\": 1024,\n",
    "    \"dropout\": 0.1,\n",
    "    \"use_bitnet\": True,\n",
    "    \"rope_theta\": 10000.0,\n",
    "}\n",
    "\n",
    "EVAL = {\n",
    "    \"batch_size\": 4,\n",
    "    \"eval_steps\": 100,\n",
    "}\n",
    "\n",
    "PATHS = {\n",
    "    \"config\": f\"{DRIVE_BASE}/model_config.json\",\n",
    "    \"meta\": f\"{DRIVE_BASE}/dataset_meta.json\",\n",
    "    \"val_shards\": f\"{DRIVE_BASE}/data_shards_val\",\n",
    "    \"checkpoint\": f\"{DRIVE_BASE}/checkpoints/checkpoint_1000.pt\",  # Change to your checkpoint\n",
    "}\n",
    "\n",
    "print(f\"Checkpoint: {PATHS['checkpoint']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "dataset"
   },
   "source": [
    "## 5. Dataset (validation shards)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "dataset_cell"
   },
   "outputs": [],
   "source": [
    "class ShardedDataset(Dataset):\n",
    "    def __init__(self, shard_dir, tokens_per_shard, vocab_size):\n",
    "        self.shard_dir = shard_dir\n",
    "        self.tokens_per_shard = tokens_per_shard\n",
    "        self.vocab_size = vocab_size\n",
    "        self.shard_files = sorted([f for f in os.listdir(shard_dir) if f.endswith(\".bin\")])\n",
    "        self.total_tokens = 0\n",
    "        self.shard_offsets = [0]\n",
    "        \n",
    "        for f in self.shard_files:\n",
    "            path = os.path.join(shard_dir, f)\n",
    "            size = os.path.getsize(path) // 2\n",
    "            self.total_tokens += size - 1\n",
    "            self.shard_offsets.append(self.total_tokens)\n",
    "        \n",
    "        print(f\"Loaded {len(self.shard_files)} val shards, {self.total_tokens:,} tokens\")\n",
    "    \n",
    "    def __len__(self):\n",
    "        return self.total_tokens\n",
    "    \n",
    "    def __getitem__(self, idx):\n",
    "        shard_idx = 0\n",
    "        for i, offset in enumerate(self.shard_offsets[:-1]):\n",
    "            if idx < self.shard_offsets[i+1]:\n",
    "                shard_idx = i\n",
    "                break\n",
    "        \n",
    "        local_idx = idx - self.shard_offsets[shard_idx]\n",
    "        path = os.path.join(self.shard_dir, self.shard_files[shard_idx])\n",
    "        arr = np.fromfile(path, dtype=np.uint16)\n",
    "        seq_len = min(1024, len(arr) - local_idx - 1)\n",
    "        x = arr[local_idx:local_idx + seq_len]\n",
    "        y = arr[local_idx + 1:local_idx + seq_len + 1]\n",
    "        return torch.tensor(x, dtype=torch.long), torch.tensor(y, dtype=torch.long)\n",
    "\n",
    "with open(PATHS[\"meta\"], \"r\") as f:\n",
    "    meta = json.load(f)\n",
    "\n",
    "val_dataset = ShardedDataset(PATHS[\"val_shards\"], meta[\"tokens_per_shard\"], meta[\"vocab_size\"])\n",
    "val_loader = torch.utils.data.DataLoader(val_dataset, batch_size=EVAL[\"batch_size\"], shuffle=False, drop_last=True, num_workers=0)"
   ]
  },
  "cell_type": "markdown",
   "metadata": {
    "id": "model"
   },
   "source": [
    "## 6. Model definition (same as training)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "model_cell"
   },
   "outputs": [],
   "source": [
    "import math\n",
    "from dataclasses import dataclass\n",
    "\n",
    "@dataclass\n",
    "class BitNetConfig:\n",
    "    vocab_size: int\n",
    "    n_layers: int\n",
    "    n_heads: int\n",
    "    n_kv_heads: int\n",
    "    d_model: int\n",
    "    d_ff: int\n",
    "    max_seq_len: int\n",
    "    dropout: float\n",
    "    use_bitnet: bool\n",
    "    rope_theta: float\n",
    "    \n",
    "    def __post_init__(self):\n",
    "        self.head_dim = self.d_model // self.n_heads\n",
    "\n",
    "class RMSNorm(nn.Module):\n",
    "    def __init__(self, dim, eps=1e-6):\n",
    "        super().__init__()\n",
    "        self.eps = eps\n",
    "        self.weight = nn.Parameter(torch.ones(dim))\n",
    "    def forward(self, x):\n",
    "        rms = torch.sqrt(x.pow(2).mean(-1, keepdim=True) + self.eps)\n",
    "        return self.weight * (x / rms)\n",
    "\n",
    "def precompute_freqs_cis(dim, max_seq_len, theta=10000.0):\n",
    "    freqs = 1.0 / (theta ** (torch.arange(0, dim, 2).float() / dim))\n",
    "    t = torch.arange(max_seq_len, dtype=torch.float32)\n",
    "    freqs = torch.outer(t, freqs)\n",
    "    return torch.polar(torch.ones_like(freqs), freqs)\n",
    "\n",
    "def apply_rotary_emb(x, freqs_cis):\n",
    "    x_ = torch.view_as_complex(x.float().reshape(*x.shape[:-1], -1, 2))\n",
    "    freqs_cis = freqs_cis.unsqueeze(0).unsqueeze(2)\n",
    "    return torch.view_as_real(x_ * freqs_cis).flatten(-2).type_as(x)\n",
    "\n",
    "def quantize_weights_ternary(w):\n",
    "    gamma = w.abs().mean()\n",
    "    w_scaled = w / (gamma + 1e-5)\n",
    "    w_q = torch.sign(w_scaled) * (w_scaled.abs() > 0.5).float()\n",
    "    return w_q, gamma\n",
    "\n",
    "class BitLinear(nn.Module):\n",
    "    def __init__(self, in_features, out_features, bias=False):\n",
    "        super().__init__()\n",
    "        self.weight = nn.Parameter(torch.randn(out_features, in_features) * 0.02)\n",
    "        self.bias = nn.Parameter(torch.zeros(out_features)) if bias else None\n",
    "    def forward(self, x):\n",
    "        w_q, gamma = quantize_weights_ternary(self.weight)\n",
    "        w = w_q * gamma + (self.weight - self.weight.detach())\n",
    "        return F.linear(x, w, self.bias)\n",
    "\n",
    "class GroupedQueryAttention(nn.Module):\n",
    "    def __init__(self, config):\n",
    "        super().__init__()\n",
    "        self.n_heads = config.n_heads\n",
    "        self.n_kv_heads = config.n_kv_heads\n",
    "        self.head_dim = config.head_dim\n",
    "        self.n_rep = self.n_heads // self.n_kv_heads\n",
    "        Linear = BitLinear if config.use_bitnet else nn.Linear\n",
    "        self.wq = Linear(config.d_model, self.n_heads * self.head_dim, bias=False)\n",
    "        self.wk = Linear(config.d_model, self.n_kv_heads * self.head_dim, bias=False)\n",
    "        self.wv = Linear(config.d_model, self.n_kv_heads * self.head_dim, bias=False)\n",
    "        self.wo = Linear(self.n_heads * self.head_dim, config.d_model, bias=False)\n",
    "        self.dropout = nn.Dropout(config.dropout)\n",
    "    def forward(self, x, freqs_cis, mask=None):\n",
    "        batch, seq_len, _ = x.shape\n",
    "        q = self.wq(x).view(batch, seq_len, self.n_heads, self.head_dim)\n",
    "        k = self.wk(x).view(batch, seq_len, self.n_kv_heads, self.head_dim)\n",
    "        v = self.wv(x).view(batch, seq_len, self.n_kv_heads, self.head_dim)\n",
    "        q = apply_rotary_emb(q, freqs_cis[:seq_len])\n",
    "        k = apply_rotary_emb(k, freqs_cis[:seq_len])\n",
    "        k = k.repeat_interleave(self.n_rep, dim=2)\n",
    "        v = v.repeat_interleave(self.n_rep, dim=2)\n",
    "        q = q.transpose(1, 2)\n",
    "        k = k.transpose(1, 2)\n",
    "        v = v.transpose(1, 2)\n",
    "        scores = torch.matmul(q, k.transpose(-2, -1)) / math.sqrt(self.head_dim)\n",
    "        if mask is not None:\n",
    "            scores = scores + mask\n",
    "        attn = self.dropout(F.softmax(scores, dim=-1))\n",
    "        out = torch.matmul(attn, v)\n",
    "        out = out.transpose(1, 2).contiguous().view(batch, seq_len, -1)\n",
    "        return self.wo(out)\n",
    "\n",
    "class SwiGLU(nn.Module):\n",
    "    def __init__(self, config):\n",
    "        super().__init__()\n",
    "        Linear = BitLinear if config.use_bitnet else nn.Linear\n",
    "        self.w1 = Linear(config.d_model, config.d_ff, bias=False)\n",
    "        self.w2 = Linear(config.d_ff, config.d_model, bias=False)\n",
    "        self.w3 = Linear(config.d_model, config.d_ff, bias=False)\n",
    "        self.dropout = nn.Dropout(config.dropout)\n",
    "    def forward(self, x):\n",
    "        return self.w2(F.silu(self.w1(x)) * self.w3(x))\n",
    "\n",
    "class TransformerBlock(nn.Module):\n",
    "    def __init__(self, config):\n",
    "        super().__init__()\n",
    "        self.attn = GroupedQueryAttention(config)\n",
    "        self.ffn = SwiGLU(config)\n",
    "        self.attn_norm = RMSNorm(config.d_model)\n",
    "        self.ffn_norm = RMSNorm(config.d_model)\n",
    "    def forward(self, x, freqs_cis, mask=None):\n",
    "        x = x + self.attn(self.attn_norm(x), freqs_cis, mask)\n",
    "        x = x + self.ffn(self.ffn_norm(x))\n",
    "        return x\n",
    "\n",
    "class BitNetTransformer(nn.Module):\n",
    "    def __init__(self, config):\n",
    "        super().__init__()\n",
    "        self.config = config\n",
    "        self.tok_embeddings = nn.Embedding(config.vocab_size, config.d_model)\n",
    "        self.layers = nn.ModuleList([TransformerBlock(config) for _ in range(config.n_layers)])\n",
    "        self.norm = RMSNorm(config.d_model)\n",
    "        self.output = nn.Linear(config.d_model, config.vocab_size, bias=False)\n",
    "        self.output.weight = self.tok_embeddings.weight\n",
    "        self.register_buffer(\"freqs_cis\", precompute_freqs_cis(config.head_dim, config.max_seq_len, config.rope_theta))\n",
    "        self.apply(self._init_weights)\n",
    "    def _init_weights(self, module):\n",
    "        if isinstance(module, nn.Linear):\n",
    "            torch.nn.init.normal_(module.weight, mean=0.0, std=0.02)\n",
    "            if module.bias is not None:\n",
    "                torch.nn.init.zeros_(module.bias)\n",
    "        elif isinstance(module, nn.Embedding):\n",
    "            torch.nn.init.normal_(module.weight, mean=0.0, std=0.02)\n",
    "    def forward(self, input_ids, targets=None):\n",
    "        batch, seq_len = input_ids.shape\n",
    "        x = self.tok_embeddings(input_ids)\n",
    "        mask = torch.triu(torch.full((seq_len, seq_len), float(\"-inf\")), diagonal=1)\n",
    "        for layer in self.layers:\n",
    "            x = layer(x, self.freqs_cis[:seq_len], mask)\n",
    "        x = self.norm(x)\n",
    "        logits = self.output(x)\n",
    "        loss = None\n",
    "        if targets is not None:\n",
    "            loss = F.cross_entropy(logits.view(-1, logits.size(-1)), targets.view(-1))\n",
    "        return logits, loss\n",
    "\n",
    "    def count_parameters(self):\n",
    "        return sum(p.numel() for p in self.parameters())"
   ]
  },
  "cell_type": "markdown",
  "metadata": {
    "id": "load_ckpt"
   },
   "source": [
    "## 7. Load model + checkpoint"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "load_ckpt_cell"
   },
   "outputs": [],
   "source": [
    "config = BitNetConfig(**CONFIG)\n",
    "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "model = BitNetTransformer(config).to(device)\n",
    "print(f\"Model: {model.count_parameters() / 1e6:.2f}M params\")\n",
    "\n",
    "if os.path.exists(PATHS[\"checkpoint\"]):\n",
    "    ckpt = torch.load(PATHS[\"checkpoint\"], map_location=device)\n",
    "    model.load_state_dict(ckpt[\"model_state_dict\"])\n",
    "    print(f\"Loaded checkpoint: {PATHS['checkpoint']}\")\n",
    "else:\n",
    "    print(f\"Checkpoint not found: {PATHS['checkpoint']}\")\n",
    "    exit(1)\n",
    "\n",
    "model.eval()"
   ]
  },
  "cell_type": "markdown",
   "metadata": {
    "id": "evaluate"
   },
   "source": [
    "## 8. Evaluation loop"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "evaluate_cell"
   },
   "outputs": [],
   "source": [
    "total_loss = 0.0\n",
    "total_tokens = 0\n",
    "\n",
    "print(f\"\\nEvaluating on {EVAL['eval_steps']} steps...\")\n",
    "for step, (x, y) in tqdm(enumerate(val_loader), total=EVAL[\"eval_steps\"], desc=\"Eval\"):\n",
    "    if step >= EVAL[\"eval_steps\"]:\n",
    "        break\n",
    "    \n",
    "    x, y = x.to(device), y.to(device)\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        _, loss = model(x, y)\n",
    "    \n",
    "    batch_tokens = x.numel()\n",
    "    total_loss += loss.item() * batch_tokens\n",
    "    total_tokens += batch_tokens\n",
    "\n",
    "avg_loss = total_loss / total_tokens\n",
    "ppl = math.exp(avg_loss)\n",
    "\n",
    "print(f\"\\n{'='*50}\")\n",
    "print(f\"Validation Loss:  {avg_loss:.4f}\")\n",
    "print(f\"Perplexity:       {ppl:.2f}\")\n",
    "print(f\"Total tokens:     {total_tokens:,}\")\n",
    "print(f\"{'='*50}\")"
   ]
  },
  "cell_type": "markdown",
   "metadata": {
    "id": "summary"
   },
   "source": [
    "---\n",
    "\n",
    "✅ Evaluation complete! Results saved to Drive:\n",
    "- Checkpoint used: `PATHS['checkpoint']`\n",
    "- Results: loss & perplexity printed above"
   ]
  }
 ],
